<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Railway Automated Test Suite" preserve-order="false">
    <listeners>
        <!-- Thêm reporter mặc định để tự động xuất file emailable-report.html -->
        <listener class-name="org.testng.reporters.EmailableReporter2" />
        <listener class-name="common.TestListener" />
    </listeners>

    <test name="Safe Railway Tests" preserve-order="false">
        <classes>
            <class name="testcases.LoginTests" />
            <class name="testcases.RegisterTests" />
            <class name="testcases.PasswordTests" />
            <class name="testcases.TicketManageTests" />
        </classes>
    </test>
</suite>
