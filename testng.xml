<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Railway Automated Test Suite">
    <!-- Listener configuration to capture screenshots on failure -->
    <listeners>
        <listener class-name="testcases.TestListener" />
    </listeners>

    <test name="Safe Railway Tests">
        <classes>
            <class name="testcases.LoginTests" />
            <class name="testcases.RegisterTests" />
            <class name="testcases.PasswordTests" />
            <class name="testcases.TicketManageTests" />
        </classes>
    </test>
</suite>
